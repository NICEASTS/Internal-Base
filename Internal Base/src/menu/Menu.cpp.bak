                        ImGui::PushStyleColor(ImGuiCol_ChildBg, FAT_ODD);
                        ImGui::PushStyleColor(ImGuiCol_Border, FAT_OUTLINE);
                        ImGui::BeginChild("##wl", ImVec2(contentW, 350), true);
                        {
                            for (int i = 0; i < (int)skins.size(); i++) {
                                
                                if (!q.empty()) { std::string n = skins[i].name; std::transform(n.begin(), n.end(), n.begin(), ::tolower); if (n.find(q) == std::string::npos) continue; }
