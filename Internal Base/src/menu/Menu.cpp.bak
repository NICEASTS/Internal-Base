                    if (wn && curWep != WEP_NONE) {
                        bool isFixed = Globals::sc_fix_skin_weapons.count((int)curWep) > 0;
                        
                        if (isFixed) {
                            ImGui::PushStyleColor(ImGuiCol_Button, ImVec4(accent.x * 0.3f, accent.y * 0.3f, accent.z * 0.3f, 1.0f));
