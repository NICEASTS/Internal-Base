                        if (ImGui::Button("Save##2", ImVec2(145, 26))) Config::Save(Config::configs[sel_cfg]);
                        if (ImGui::Button("Delete", ImVec2(300, 26))) { Config::Delete(Config::configs[sel_cfg]); sel_cfg = -1; }
